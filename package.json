{
  "name": "office-ai-agent",
  "version": "0.1.0",
  "description": "Office AI Agent - cross-platform desktop app with custom agents, skills, chatrooms, and teams",
  "main": "dist-main/main/index.js",
  "author": "Office AI Agent Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && node scripts/launch-electron.cjs . --dev",
    "dev:renderer": "vite",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "node scripts/launch-electron.cjs .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.2.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "@types/better-sqlite3": "^7.6.0"
  },
  "overrides": {
    "tinyglobby": "^0.2.10"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "zustand": "^4.5.0",
    "better-sqlite3": "^11.0.0",
    "openai": "^4.47.0",
    "marked": "^12.0.0",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.378.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.3.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "node-fetch": "^3.3.0",
    "uuid": "^9.0.0",
    "@types/uuid": "^9.0.0"
  }
}
